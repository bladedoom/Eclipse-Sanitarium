  dialogueLines_Ch:
  - speakerName: "\u5217\u592B\xB7\u53F6\u83F2\u83AB\u592B\t"
    dialogueText: "\u6BDB\u5DFE\uFF01\u7ED9\u6211\u6E7F\u6BDB\u5DFE\uFF01\u6211\u7684\u76AE\u80A4\u2026\u2026\u50CF\u6728\u5934\u4E00\u6837\u5E72\u88C2\u2026\u2026\u5728\u53D1\u51FA\u58F0\u97F3\uFF01"
    waitForInput: 1
    autoContinueDelay: 0
  - speakerName: "\u5217\u592B\xB7\u53F6\u83F2\u83AB\u592B\t"
    dialogueText: "\u4E09\u697C\u2026\u2026\u50A8\u85CF\u5BA4\u2026\u2026\u90A3\u91CC\u7684\u6BDB\u5DFE\u2026\u2026\u6700\u6E7F\u6DA6\u2026\u2026"
    waitForInput: 1
    autoContinueDelay: 0
  dialogueLines_En:
  - speakerName: 
    dialogueText: "Towel! Give me a wet towel! My skin\u2026cracking like wood\u2026it's
      making sounds!"
    waitForInput: 1
    autoContinueDelay: 0
  - speakerName: 
    dialogueText: "Third floor\u2026storage room\u2026the towels there\u2026are the
      wettest\u2026"
    waitForInput: 1
    autoContinueDelay: 0
