  dialogueId: 10
  dialogueLines_Ch:
  - speakerName: "\u62A4\u58EB\u957F"
    dialogueText: "\u6211\u5C0A\u91CD\u4F60\u7684\u9009\u62E9\uFF0C\u4F46\u65E0\u6CD5\u5141\u8BB8\u4F60\u5C06\u6C61\u67D3\u5E26\u51FA\u53BB\u3002"
    waitForInput: 1
    autoContinueDelay: 0
  - speakerName: "\u62A4\u58EB\u957F"
    dialogueText: "\u6211\u4F1A\u963B\u6B62\u4F60\u3002\u8FD9\u662F\u4E3A\u4E86\u4FDD\u62A4\u5916\u9762\u7684\u4E16\u754C\u2026\u2026\u4E5F\u4E3A\u4E86\u4FDD\u62A4\u4F60\u3002"
    waitForInput: 1
    autoContinueDelay: 0
  dialogueLines_En:
  - speakerName: 
    dialogueText: I respect your choice, but I cannot allow you to take the contamination
      out.
    waitForInput: 1
    autoContinueDelay: 0
  - speakerName: 
    dialogueText: "I will stop you. This is to protect the outside world\u2026and
      to protect you."
    waitForInput: 1
    autoContinueDelay: 0
  closeOnComplete: 1
  CurrentTaskWillComplete: 1
