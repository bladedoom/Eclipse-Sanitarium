  dialogueId: 5
  dialogueLines_Ch:
  - speakerName: "\u62A4\u58EB\u957F"
    dialogueText: "203\u53F7\u75C5\u4EBA\u674E\u660E\u9633\uFF0C\u5DF2\u8F6C\u5165\u6DF1\u5EA6\u5B89\u5B81\u7597\u517B\u9636\u6BB5\u3002\u8FD9\u662F\u9884\u671F\u5185\u7684\u8FDB\u5C55\u3002"
    waitForInput: 1
    autoContinueDelay: 0
  - speakerName: "\u62A4\u58EB\u957F"
    dialogueText: "\u4F60\u4F3C\u4E4E\u53D7\u5230\u4E86\u60CA\u5413\u3002\u8FC7\u5EA6\u5171\u60C5\u5BF9\u62A4\u5DE5\u65E0\u76CA\u3002\u53BB\u56FE\u4E66\u9986\u6574\u7406\u4E00\u4E0B\u65E7\u6863\u6848\u5427\uFF0C\u90A3\u91CC\u5B89\u9759\u3002"
    waitForInput: 1
    autoContinueDelay: 0
  dialogueLines_En:
  - speakerName: 
    dialogueText: Patient Li Mingyang in Room 203 has been transferred to the deep
      palliative care phase. This is expected progress.
    waitForInput: 1
    autoContinueDelay: 0
  - speakerName: 
    dialogueText: You seem frightened. Excessive empathy is not good for an orderly.
      Go organize the old archives in the library. It's quiet there.
    waitForInput: 1
    autoContinueDelay: 0
  closeOnComplete: 1
  CurrentTaskWillComplete: 0
